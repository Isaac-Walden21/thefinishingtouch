# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── App ──
NEXT_PUBLIC_APP_URL=        # CRM base URL (e.g., https://app.thefinishingtouchllc.com)

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=      # Webhook signing secret from Stripe dashboard

# ── Resend (email) ──
RESEND_API_KEY=

# ── AI ──
GEMINI_API_KEY=             # Google Gemini for Vision Studio image generation
OPENAI_API_KEY=             # OpenAI for AI Estimator and chatbot

# ── Vapi (AI phone receptionist) ──
VAPI_API_KEY=               # API key shared with Vapi for webhook auth

# ── QuickBooks Online ──
QUICKBOOKS_CLIENT_ID=       # OAuth2 client ID from Intuit Developer
QUICKBOOKS_CLIENT_SECRET=   # OAuth2 client secret
QUICKBOOKS_REALM_ID=        # Company ID (set after OAuth connect)
QUICKBOOKS_REFRESH_TOKEN=   # OAuth2 refresh token (set after OAuth connect)
QUICKBOOKS_SANDBOX=false    # Set to "true" for sandbox environment

# ── Google Calendar ──
GOOGLE_CALENDAR_CLIENT_ID=      # OAuth2 client ID from Google Cloud Console
GOOGLE_CALENDAR_CLIENT_SECRET=  # OAuth2 client secret
GOOGLE_CALENDAR_REFRESH_TOKEN=  # OAuth2 refresh token (set after OAuth connect)
GOOGLE_CALENDAR_ID=primary      # Calendar ID (default: primary)

# ── Twilio (SMS) ──
TWILIO_ACCOUNT_SID=         # Account SID from Twilio Console
TWILIO_AUTH_TOKEN=           # Auth token from Twilio Console
TWILIO_PHONE_NUMBER=        # Twilio phone number (E.164 format, e.g., +17651234567)

# ── Google Places ──
GOOGLE_PLACES_API_KEY=      # API key with Places API enabled
